# ─── Supabase ─────────────────────────────────────────────────────────────────
# URL del proyecto (misma que VITE_SUPABASE_URL en la SPA)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key — NUNCA expongas esta clave en el frontend.
# La encontrás en: Supabase → Settings → API → service_role secret
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Claude / Anthropic ───────────────────────────────────────────────────────
# La encontrás en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# Origen(es) permitidos por CORS (separados por coma si son varios)
# En desarrollo podés usar * para permitir todo.
# En producción usá el dominio exacto: https://gatoencerrado.com
ALLOWED_ORIGIN=http://localhost:5173

# ─── Opcional: búsqueda full-text en Supabase ────────────────────────────────
# Si tu tabla blog_posts NO tiene una columna `fts` generada, el servidor
# cae automáticamente a búsqueda ilike. Para activar FTS ejecutá en Supabase:
#
# ALTER TABLE blog_posts
#   ADD COLUMN fts tsvector
#   GENERATED ALWAYS AS (
#     to_tsvector('spanish',
#       coalesce(title, '') || ' ' ||
#       coalesce(excerpt, '') || ' ' ||
#       coalesce(content, '')
#     )
#   ) STORED;
#
# CREATE INDEX blog_posts_fts_idx ON blog_posts USING GIN(fts);
